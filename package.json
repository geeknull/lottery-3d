    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "oxlint": "~1.69.0",
    "sass": "^1.100.0",
    "typescript": "~6.0.3",
